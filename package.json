{
  "name": "ndotoni-stays",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "amplify:statements": "pnpm amplify codegen statements",
    "amplify:types": "pnpm amplify codegen types",
    "amplify:codegen": "pnpm run amplify:statements && pnpm run amplify:types",
    "schema:download": "aws appsync get-introspection-schema --api-id tpxpbec6e5crxhu277uknqxoqi --region us-west-2 --format SDL schema.graphql",
    "schema:clean": "node -e \"const fs=require('fs');let s=fs.readFileSync('schema.graphql','utf8');s=s.replace(/@aws_[a-z_]+/g,'').replace(/@[a-z]+\\\\([^)]*\\\\)/g,'');fs.writeFileSync('schema.graphql',s);\"",
    "schema:generate": "pnpm run amplify:codegen",
    "schema:update": "pnpm run schema:download && pnpm run schema:generate"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.7.2",
    "@heroicons/react": "^2.2.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "aws-amplify": "^6.0.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^4.2.1",
    "react-phone-number-input": "^3.4.17",
    "recharts": "2.15.4",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@aws-amplify/cli": "^14.5.0",
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0"
  }
}
