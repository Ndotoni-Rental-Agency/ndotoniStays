    "schema:update": "pnpm run schema:download && pnpm run schema:generate"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.7.2",
    "@heroicons/react": "^2.2.0",
    "aws-amplify": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-phone-number-input": "^3.4.17",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
